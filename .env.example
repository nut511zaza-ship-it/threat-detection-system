# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ
# cp .env.example .env

# VirusTotal API Key (สมัครฟรีได้ที่ https://www.virustotal.com/gui/join-us)
VT_API_KEY=

# Username/password สำหรับ Admin คนแรกที่ระบบจะสร้างให้อัตโนมัติตอนเริ่มต้น
# (ใช้ได้แค่ตอนยังไม่มี admin คนไหนในระบบเลย)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Gmail SMTP สำหรับส่งอีเมลกู้คืนรหัสผ่าน (Forgot Password)
# วิธีตั้งค่า:
# 1. เปิด 2-Step Verification ที่ https://myaccount.google.com/security
# 2. สร้าง App Password ที่ https://myaccount.google.com/apppasswords (เลือก app เป็น "Mail")
# 3. ใส่อีเมล Gmail และ App Password (16 หลัก) ด้านล่าง
SMTP_USER=
SMTP_APP_PASSWORD=

# URL ของเว็บไซต์ ใช้สร้างลิงก์กู้คืนรหัสผ่านในอีเมล
SITE_URL=http://143.14.200.159:8000
